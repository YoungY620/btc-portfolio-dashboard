# Copy this file to `.env.local` for local development.
# In Vercel, add the same keys under Project Settings -> Environment Variables.
#
# Only secrets belong here.
# Strategy settings, URLs, wallet addresses, and manual balances live in config/dashboard.json.
# Private local manual balances can live in ignored config/dashboard.local.json.
#
# Security:
# - Use READ-ONLY exchange API keys for this dashboard.
# - Do not enable trading, withdrawal, transfer, or margin permissions.
# - Never commit `.env.local`.

BINANCE_API_KEY=replace_with_binance_read_only_api_key
BINANCE_API_SECRET=replace_with_binance_read_only_api_secret

OKX_API_KEY=replace_with_okx_read_only_api_key
OKX_API_SECRET=replace_with_okx_read_only_api_secret
OKX_API_PASSPHRASE=replace_with_the_passphrase_you_created_for_this_okx_api_key
